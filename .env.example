# MongoDB Atlas Connection
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Voyage AI (get from MongoDB Atlas UI → AI Models → Create model API key)
VOYAGE_API_KEY=pa-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: only if you need a non-default embeddings URL (Atlas keys use ai.mongodb.com automatically)
# VOYAGE_EMBEDDINGS_URL=https://ai.mongodb.com/v1/embeddings

# Anthropic Claude (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: controls how many results vector search returns
TOP_K=5
